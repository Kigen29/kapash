{
  "expo": {
    "name": "Kapash",
    "slug": "windows-81",
    "scheme": "kapash",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1923"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kapash.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "KAPASH uses your location to show pitches near you.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.761688069800-vta7qvt6ff3hj1mnmse93fqu286fh1pi"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#0F1923"
      },
      "package": "com.kapash.app",
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "extra": {
      "eas": {
        "projectId": "59b465c7-9780-495d-bf36-a7e3892f2635"
      }
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      ["expo-image-picker", {
        "photosPermission": "Allow KAPASH to access your photos to upload pitch images."
      }],
      ["expo-notifications", {
        "icon": "./assets/images/icon.png",
        "color": "#22C55E"
      }],
      ["expo-location", {
        "locationWhenInUsePermission": "KAPASH uses your location to show pitches near you."
      }],
      "@rnmapbox/maps"
    ],
    "owner": "kigen29"
  }
}
