# Copy this file to .env and fill in your values
# All EXPO_PUBLIC_ variables are bundled into the app at build time

# ── Backend API ───────────────────────────────────────────────────────────────
# Local dev:  http://192.168.1.64:5000/api/v1  (replace IP with your machine's IP)
# Production: https://api.kapash.app/api/v1
EXPO_PUBLIC_API_URL=http://192.168.1.64:5000/api/v1

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get these from https://console.cloud.google.com → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com
