generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  PLAYER
  OWNER
  ADMIN
}

enum PitchStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum PitchType {
  ASTRO_TURF
  NATURAL_GRASS
  CONCRETE
  HYBRID
}

enum PitchSize {
  FIVE_A_SIDE
  SEVEN_A_SIDE
  ELEVEN_A_SIDE
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  MPESA
  CARD
  CASH
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
  HELD
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  PAYOUT_PROCESSED
  REVIEW_RECEIVED
  PITCH_VERIFIED
  SLOT_REMINDER
  REVIEW_REQUEST
  INVOICE_SENT
  INVOICE_OVERDUE
  GENERAL
}

enum AdminTier {
  SUPER
  OPERATIONS
  FINANCE
  SUPPORT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum EventStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ── Models ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  phone         String?   @unique          // Optional: required only after verification
  email         String?   @unique
  name          String
  avatar        String?
  role          UserRole  @default(PLAYER)
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)

  // Social auth
  googleId      String?   @unique
  appleId       String?   @unique

  // Phone verification (anti-fraud)
  phoneVerified Boolean   @default(false)
  walletBalance Float     @default(0)

  // OTP verification
  otpCode       String?
  otpExpiresAt  DateTime?

  // Push notifications
  fcmToken      String?

  // Referral system
  referralCode  String    @unique @default(uuid())
  referredBy    String?
  referralCount Int       @default(0)

  // Admin tier (only set when role = ADMIN)
  adminTier     AdminTier?

  // Corporate membership (set when this user belongs to a corporate org)
  corporateId   String?
  isCorpAdmin   Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  pitches       Pitch[]
  bookings      Booking[]
  reviews       Review[]
  notifications Notification[]
  refreshTokens RefreshToken[]
  payouts       Payout[]
  auditLogs     AuditLog[]
  corporate     Corporate?     @relation(fields: [corporateId], references: [id])
  organizedEvents BookingEvent[] @relation("EventOrganizer")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Pitch {
  id             String      @id @default(uuid())
  ownerId        String
  name           String
  description    String?     @db.Text
  address        String
  city           String      @default("Nairobi")
  county         String      @default("Nairobi")
  latitude       Float
  longitude      Float
  type           PitchType   @default(ASTRO_TURF)
  size           PitchSize   @default(SEVEN_A_SIDE)
  pricePerHour   Float
  status         PitchStatus @default(PENDING_VERIFICATION)
  isVerified     Boolean     @default(false)
  verifiedAt     DateTime?
  verifiedBy     String?
  avgRating      Float       @default(0)
  reviewCount    Int         @default(0)
  commissionRate Float       @default(0.13)
  operatingHours Json        @default("{}")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  owner     User          @relation(fields: [ownerId], references: [id])
  images    PitchImage[]
  amenities PitchAmenity[]
  bookings  Booking[]
  reviews   Review[]
  slots     TimeSlot[]
  payouts   Payout[]

  @@map("pitches")
}

model PitchImage {
  id        String   @id @default(uuid())
  pitchId   String
  url       String
  publicId  String
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  pitch Pitch @relation(fields: [pitchId], references: [id], onDelete: Cascade)

  @@map("pitch_images")
}

model PitchAmenity {
  id      String @id @default(uuid())
  pitchId String
  name    String
  icon    String @default("⚽")

  pitch Pitch @relation(fields: [pitchId], references: [id], onDelete: Cascade)

  @@map("pitch_amenities")
}

model TimeSlot {
  id          String     @id @default(uuid())
  pitchId     String
  date        DateTime   @db.Date
  startTime   String
  endTime     String
  status      SlotStatus @default(AVAILABLE)
  heldBy      String?
  heldUntil   DateTime?
  blockReason String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  pitch   Pitch    @relation(fields: [pitchId], references: [id], onDelete: Cascade)
  booking Booking?

  @@unique([pitchId, date, startTime])
  @@map("time_slots")
}

model Booking {
  id               String        @id @default(uuid())
  userId           String
  pitchId          String
  slotId           String        @unique
  pitchName        String
  pitchAddress     String
  date             DateTime      @db.Date
  startTime        String
  endTime          String
  durationMins     Int
  pricePerHour     Float
  totalAmount      Float
  commissionAmount Float
  ownerAmount      Float
  status           BookingStatus @default(PENDING_PAYMENT)
  ticketId         String        @unique @default(uuid())
  qrCode           String?
  cancelledAt      DateTime?
  cancelReason     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Event / corporate linkage (nullable — most bookings are individual)
  eventId       String?
  corporateId   String?

  user    User           @relation(fields: [userId], references: [id])
  pitch   Pitch          @relation(fields: [pitchId], references: [id])
  slot    TimeSlot       @relation(fields: [slotId], references: [id])
  payment Payment?
  payout  Payout?
  event   BookingEvent?  @relation(fields: [eventId], references: [id])

  @@map("bookings")
}

model Payment {
  id                     String        @id @default(uuid())
  bookingId              String        @unique
  userId                 String
  amount                 Float
  method                 PaymentMethod @default(MPESA)
  status                 PaymentStatus @default(PENDING)
  mpesaPhone             String?
  mpesaCheckoutRequestId String?       @unique
  mpesaMerchantRequestId String?
  mpesaReceiptNumber     String?
  mpesaTransactionDate   String?
  resultCode             String?
  resultDesc             String?
  refundedAt             DateTime?
  refundAmount           Float?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model Payout {
  id                 String       @id @default(uuid())
  ownerId            String
  pitchId            String
  bookingId          String       @unique
  amount             Float
  status             PayoutStatus @default(PENDING)
  mpesaPhone         String?
  mpesaTransactionId String?
  scheduledFor       DateTime
  processedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  owner   User    @relation(fields: [ownerId], references: [id])
  pitch   Pitch   @relation(fields: [pitchId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payouts")
}

model Review {
  id             String   @id @default(uuid())
  userId         String
  pitchId        String
  bookingId      String?
  rating         Int
  comment        String?  @db.Text
  ownerReply     String?  @db.Text
  ownerRepliedAt DateTime?
  isVisible      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  pitch Pitch @relation(fields: [pitchId], references: [id])

  @@unique([userId, bookingId])
  @@map("reviews")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String           @db.Text
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model OtpSession {
  id        String   @id @default(uuid())
  phone     String
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_sessions")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  action     String   // 'pitch.verify' | 'pitch.suspend' | 'user.deactivate' | ...
  targetType String   // 'pitch' | 'user' | 'booking' | 'payout' | 'review' | 'broadcast' | 'setting'
  targetId   String
  meta       Json?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([targetType, targetId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("system_settings")
}

// ── Corporate (B2B accounts) ──────────────────────────────────────────────────

model Corporate {
  id              String   @id @default(uuid())
  name            String
  tradingName     String?
  email           String   @unique
  phone           String
  billingAddress  String
  kraPin          String?
  status          String   @default("ACTIVE")   // ACTIVE | SUSPENDED
  creditLimit     Float    @default(0)
  paymentTermDays Int      @default(7)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookers  User[]
  events   BookingEvent[]
  invoices Invoice[]

  @@map("corporates")
}

model BookingEvent {
  id           String       @id @default(uuid())
  name         String
  organizerId  String
  corporateId  String?
  date         DateTime     @db.Date
  status       EventStatus  @default(DRAFT)
  totalAmount  Float        @default(0)
  notes        String?      @db.Text
  invoiceId    String?      @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  organizer User       @relation("EventOrganizer", fields: [organizerId], references: [id])
  corporate Corporate? @relation(fields: [corporateId], references: [id])
  bookings  Booking[]
  invoice   Invoice?   @relation(fields: [invoiceId], references: [id])

  @@index([corporateId, status])
  @@index([date])
  @@map("booking_events")
}

model Invoice {
  id          String        @id @default(uuid())
  number      String        @unique          // e.g. "INV-2026-0001"
  corporateId String
  amount      Float
  tax         Float         @default(0)
  total       Float
  status      InvoiceStatus @default(DRAFT)
  issuedAt    DateTime      @default(now())
  dueDate     DateTime
  paidAt      DateTime?
  paymentRef  String?
  lineItems   Json
  notes       String?       @db.Text
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  corporate Corporate     @relation(fields: [corporateId], references: [id])
  event     BookingEvent?

  @@index([corporateId, status])
  @@map("invoices")
}

// ── Global amenities catalog (separate from PitchAmenity join rows) ───────────

model Amenity {
  id        String   @id @default(uuid())
  name      String   @unique
  icon      String   @default("⚽")
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("amenities_catalog")
}